# ── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── AI / Claude ──────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Model: claude-sonnet-4-6 (production) or claude-haiku-4-5-20251001 (cheaper/faster)
AI_MODEL=claude-sonnet-4-6
AI_TIMEOUT_MS=10000

# ── Email / Resend ───────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=hello@endevo.life
EMAIL_REPLY_TO=hello@endevo.life

# ── GoHighLevel CRM ──────────────────────────────────
# Step 1 (required): GHL > Settings > Business Profile
GHL_API_KEY=your_ghl_location_api_key_here
GHL_LOCATION_ID=your_ghl_location_id_here

# Step 2 (optional): adds leads to a visual pipeline
# Get IDs by calling GET https://rest.gohighlevel.com/v1/pipelines/
GHL_PIPELINE_ID=your_pipeline_id_here

# Pipeline Stage IDs — one per quiz tier (from GET /v1/pipelines/ response)
GHL_STAGE_STARTING_FRESH=stage_id_for_starting_fresh
GHL_STAGE_GETTING_CLARITY=stage_id_for_getting_clarity
GHL_STAGE_ON_YOUR_WAY=stage_id_for_on_your_way
GHL_STAGE_PEACE_CHAMPION=stage_id_for_peace_champion

# Step 3 (optional): custom field IDs from GHL > Settings > Custom Fields
# Create these fields in GHL first, then paste the IDs here
GHL_FIELD_SCORE=field_id_readiness_score
GHL_FIELD_TIER=field_id_jesse_tier
GHL_FIELD_GAPS=field_id_critical_gaps
GHL_FIELD_LOWEST_DOMAIN=field_id_weakest_domain
GHL_FIELD_SIGNALS=field_id_jesse_signals

# ── CORS ─────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_URLS=http://localhost:3000,http://localhost:5173
